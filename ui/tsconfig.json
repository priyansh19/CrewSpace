{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "lexical": ["./node_modules/lexical/index.d.ts"],
      "hermes-crewspace-adapter": ["../packages/adapters/hermes-crewspace-adapter/dist/index.d.ts"],
      "hermes-crewspace-adapter/server": ["../packages/adapters/hermes-crewspace-adapter/dist/server/index.d.ts"],
      "hermes-crewspace-adapter/ui": ["../packages/adapters/hermes-crewspace-adapter/dist/ui/index.d.ts"],
      "hermes-crewspace-adapter/cli": ["../packages/adapters/hermes-crewspace-adapter/dist/cli/index.d.ts"]
    }
  },
  "include": ["src"]
}
